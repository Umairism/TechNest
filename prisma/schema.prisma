// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// User Model - Authentication & Customer Management
model User {
  id        String     @id @default(cuid())
  email     String     @unique
  name      String?
  password  String?
  phone     String?
  role      UserRole   @default(customer)
  status    UserStatus @default(active)
  address   String?
  city      String?
  zipCode   String?
  lastLoginAt DateTime?
  
  // Relations
  cart      Cart?
  orders    Order[]
  addresses ShippingAddress[]
  auditLogs AuditLog[]
  notifications Notification[]
  reviews   ProductReview[]
  
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([role])
  @@index([status])
  @@map("users")
}

enum UserRole {
  customer
  vendor
  moderator
  admin
}

enum UserStatus {
  active
  suspended
  banned
  pending_verification
}

// Product Model - Core Product Data
model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String   @db.Text
  sku         String   @unique
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  
  price       Float    // Current price
  originalPrice Float? // Original price for discounts
  
  brand       String?
  images      String[] // Store URLs as JSON array
  specifications Json?  // Store as JSON for flexibility
  tags        String[]  @default([])
  variants    Json?
  
  stock       Int      @default(0)
  featured    Boolean  @default(false)
  trending    Boolean  @default(false)
  hidden      Boolean  @default(false)
  draft       Boolean  @default(false)
  active      Boolean  @default(true)
  status      ProductStatus @default(published)
  rejectionReason String?
  publishedAt DateTime?
  
  // Relations
  orderItems  OrderItem[]
  cartItems   CartItem[]
  inventory   Inventory?
  collections CollectionProduct[]
  productCategories ProductCategory[]
  reviews ProductReview[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([categoryId])
  @@index([slug])
  @@index([status])
  @@index([featured])
  @@index([trending])
  @@map("products")
}

enum ProductStatus {
  pending
  approved
  rejected
  published
  draft
  hidden
  out_of_stock
}

// Category Model - Product Organization
model Category {
  id       String    @id @default(cuid())
  name     String    @unique
  slug     String    @unique
  description String?
  parentId String?
  parent   Category? @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[] @relation("CategoryTree")
  bannerUrl String?
  thumbnailUrl String?
  seoTitle String?
  seoDescription String?
  sortOrder Int @default(0)
  featured Boolean @default(false)
  
  products Product[]
  productCategories ProductCategory[]
  
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([parentId])
  @@index([sortOrder])
  @@map("categories")
}

model ProductCategory {
  id         String   @id @default(cuid())
  productId String
  categoryId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category  Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([productId, categoryId])
  @@map("product_categories")
}

model Collection {
  id          String @id @default(cuid())
  name        String
  slug        String @unique
  description String?
  imageUrl    String?
  active      Boolean @default(true)
  sortOrder   Int @default(0)
  startsAt    DateTime?
  endsAt      DateTime?

  products CollectionProduct[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active])
  @@map("collections")
}

model CollectionProduct {
  id           String @id @default(cuid())
  collectionId String
  productId    String
  sortOrder    Int @default(0)
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  product      Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([collectionId, productId])
  @@map("collection_products")
}

// Inventory Model - Stock Management
model Inventory {
  id          String  @id @default(cuid())
  productId   String  @unique
  product     Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  quantity    Int     @default(0)
  reserved    Int     @default(0) // Reserved for pending orders
  sold        Int     @default(0)  // Total sold
  
  lastUpdated DateTime @default(now()) @updatedAt
  
  @@map("inventory")
}

// Cart Model - Shopping Cart
model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  items     CartItem[]
  
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@map("carts")
}

// CartItem Model - Individual Cart Items
model CartItem {
  id        String  @id @default(cuid())
  cartId    String
  cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  quantity  Int
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cartId, productId])
  @@map("cart_items")
}

// Order Model - Order Management
model Order {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  orderNumber   String      @unique // Custom order number for customer communication
  status        OrderStatus @default(pending)
  paymentStatus PaymentStatus @default(unpaid)
  paymentMethod PaymentMethod
  
  subtotal      Float
  tax           Float
  shippingCost  Float       @default(0)
  totalAmount   Float
  
  shippingAddress String    // Store as JSON
  billingAddress  String?   // Store as JSON
  
  items         OrderItem[]
  payment       Payment?
  
  notes         String?
  trackingId    String?
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  
  @@index([userId])
  @@index([orderNumber])
  @@map("orders")
}

enum OrderStatus {
  pending
  confirmed
  processing
  shipped
  delivered
  cancelled
  refunded
}

enum PaymentStatus {
  unpaid
  paid
  failed
  refunded
}

enum PaymentMethod {
  cod           // Cash on Delivery
  jazzcash      // JazzCash Mobile Money
  easypaisa     // EasyPaisa Mobile Money
  card          // Debit/Credit Cards
}

// OrderItem Model - Individual Order Items
model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  productId String
  product   Product @relation(fields: [productId], references: [id])
  
  quantity  Int
  price     Float   // Price at time of purchase
  total     Float   // quantity * price
  
  @@map("order_items")
}

// Payment Model - Payment Tracking (Pakistan-Specific)
model Payment {
  id            String        @id @default(cuid())
  orderId       String        @unique
  order         Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  amount        Float
  currency      String        @default("PKR")
  method        PaymentMethod
  status        PaymentStatus @default(unpaid)
  
  // Payment gateway specific
  gatewayId     String?       // Transaction ID from PayFast/Stripe etc
  reference     String?       // Customer reference number
  
  attempt       Int           @default(1)
  lastAttempt   DateTime      @default(now())
  
  // For COD
  isCollected   Boolean       @default(false)
  collectedAt   DateTime?
  
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  
  @@index([gatewayId])
  @@map("payments")
}

model ProductReview {
  id        String @id @default(cuid())
  productId String
  userId    String
  rating    Int
  title     String?
  comment   String?
  status    ModerationStatus @default(pending)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@map("product_reviews")
}

enum ModerationStatus {
  pending
  approved
  rejected
  archived
}

// Shipping Address Model - Multiple Addresses
model ShippingAddress {
  id       String  @id @default(cuid())
  userId   String
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  name     String
  phone    String
  email    String
  address  String
  city     String
  zipCode  String
  isDefault Boolean @default(false)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@map("shipping_addresses")
}

// Session Model - NextAuth Sessions
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model SiteContent {
  id          String @id @default(cuid())
  key         String @unique
  type        ContentType
  title       String?
  body        String?
  data        Json?
  imageUrl    String?
  active      Boolean @default(true)
  publishedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@map("site_content")
}

enum ContentType {
  hero
  banner
  featured_section
  testimonial
  faq
  about
  contact
  footer
  navigation
  announcement
  seo
  social
}

model MediaAsset {
  id          String @id @default(cuid())
  filename    String
  originalName String
  url         String
  mimeType    String
  size        Int
  folder      String?
  altText     String?
  width       Int?
  height      Int?
  optimized   Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([folder])
  @@map("media_assets")
}

model AdminSetting {
  id        String @id @default(cuid())
  group     String
  key       String
  value     Json
  encrypted Boolean @default(false)

  updatedAt DateTime @updatedAt

  @@unique([group, key])
  @@map("admin_settings")
}

model Notification {
  id        String @id @default(cuid())
  userId    String?
  type      NotificationType
  title     String
  message   String
  severity  AlertSeverity @default(info)
  read      Boolean @default(false)
  data      Json?
  user      User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([type])
  @@index([read])
  @@map("notifications")
}

enum NotificationType {
  order
  product_approval
  vendor_request
  user_report
  low_stock
  system
}

enum AlertSeverity {
  info
  success
  warning
  critical
}

model AuditLog {
  id        String @id @default(cuid())
  actorId   String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  ipAddress String?
  userAgent String?
  actor     User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([actorId])
  @@index([entity])
  @@map("audit_logs")
}

model Coupon {
  id        String @id @default(cuid())
  code      String @unique
  type      CouponType
  value     Float
  active    Boolean @default(true)
  startsAt  DateTime?
  expiresAt DateTime?
  maxUses   Int?
  usedCount Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active])
  @@map("coupons")
}

enum CouponType {
  percentage
  fixed_amount
  free_shipping
}

model FeatureFlag {
  id          String @id @default(cuid())
  key         String @unique
  description String?
  enabled     Boolean @default(false)
  rollout     Int @default(100)

  updatedAt DateTime @updatedAt

  @@map("feature_flags")
}
